{
  "consumer": {
    "name": "trello-management-api-playwright"
  },
  "interactions": [
    {
      "description": "create board",
      "providerStates": [
        {
          "name": "Board can be created"
        }
      ],
      "request": {
        "body": "defaultLists=false&key=***&name=TEST_PACT&token=***",
        "headers": {
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "matchingRules": {
          "body": {
            "$.defaultLists": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.key": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/1/boards"
      },
      "response": {
        "body": {
          "closed": false,
          "id": "abc123",
          "name": "TEST_PACT"
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.closed": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "get board by id",
      "providerStates": [
        {
          "name": "Board exists"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "matchingRules": {
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "regex",
                "regex": "\\/1\\/boards\\/[\\w-]+"
              }
            ]
          }
        },
        "method": "GET",
        "path": "/1/boards/abc123"
      },
      "response": {
        "body": {
          "closed": false,
          "id": "abc123",
          "name": "TEST_PACT"
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.closed": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.2.0"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "trello-api"
  }
}